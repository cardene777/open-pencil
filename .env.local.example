# Pencil Editor — ローカル開発用環境変数
#
# 使い方:
#   cp .env.local.example .env.local
#   bun run dev:full
#
# 機能の有効化:
#   - Google ログイン: INKLY_API_GOOGLE_CLIENT_ID / INKLY_API_GOOGLE_CLIENT_SECRET に値を設定
#   - 招待メール送信: INKLY_API_RESEND_KEY に値を設定
#   - Turso 接続: TURSO_DATABASE_URL / TURSO_AUTH_TOKEN に値を設定 (空なら local SQLite)

INKLY_API_AUTH_SECRET=dev-only-auth-secret-min-32-chars-please-replace
INKLY_API_JWT_SECRET=dev-only-jwt-secret-min-32-chars-please-replace

INKLY_API_GOOGLE_CLIENT_ID=
INKLY_API_GOOGLE_CLIENT_SECRET=

INKLY_API_RESEND_KEY=

TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
