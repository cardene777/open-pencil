# Pencil Editor — dev / staging / preview 環境用環境変数
#
# CI / preview deploy / staging 環境で使う想定。
# secret は CI / hosting platform の secrets manager で注入する。
# このファイルは「必要な変数一覧」を示すテンプレート (値は空)。

INKLY_API_AUTH_SECRET=
INKLY_API_JWT_SECRET=

INKLY_API_GOOGLE_CLIENT_ID=
INKLY_API_GOOGLE_CLIENT_SECRET=

# Allowed email domains (comma-separated). Empty = no restriction.
INKLY_API_ALLOWED_EMAIL_DOMAINS=

INKLY_API_RESEND_KEY=

TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
