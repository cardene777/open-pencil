# Pencil Editor — ローカル開発用環境変数テンプレート
#
# 使い方:
#   cp .env.development.example .env.development
#   bun run dev:full
#
# 本番では絶対にこの値を使わない (ダミー dev 値)。

# === API server (port 3001) ===
# Better Auth 用 secret (32 文字以上必須)
INKLY_API_AUTH_SECRET=dev-only-auth-secret-min-32-chars-please-replace

# JWT 用 secret (32 文字以上必須)
INKLY_API_JWT_SECRET=dev-only-jwt-secret-min-32-chars-please-replace

# DB モード (memory = 起動毎にリセット、 file = packages/api/inkly.db に永続化)
INKLY_API_DB_MODE=memory

# 招待 token sweep の自動実行 (1 = 有効、 未設定 = 無効)
INKLY_API_AUTO_SWEEP=0

# Test utility ルート (/api/auth/test/login 等) を有効化
# AUTH_TEST_MODE を使う場合は必須
INKLY_API_AUTH_ENABLE_TEST_UTILS=1

# Google OAuth (実際に Google ログインを試す場合のみ設定)
# 未設定だと Google ボタンは "Google login is not configured" を返す
# INKLY_API_GOOGLE_CLIENT_ID=
# INKLY_API_GOOGLE_CLIENT_SECRET=

# Resend メール送信 (招待メールを実際に送る場合のみ設定)
# INKLY_API_RESEND_KEY=

NODE_ENV=development

# === Vite dev server (port 1420) ===
# Auth test mode を有効化すると "Google でログイン" が
# playwright-user@inkly.test として瞬時に成功する (DB は memory なので毎回新規)
VITE_INKLY_AUTH_TEST_MODE=1
